# Copy to Netlify: Site settings → Environment variables → Production
# (Vercel env vars do not migrate automatically.)
#
# Download URL is optional when the .dmg lives in public/ (e.g. public/Smile-0.25.0.dmg).
# Override only if you host the installer elsewhere:

# SMILE_DOWNLOAD_URL=https://advision.com/Smile-0.25.0.dmg
# SMILE_DOWNLOAD_BASE_URL=https://downloads.example.com/smile

# Support email shown on /smile/support and legal pages
# SMILE_SUPPORT_EMAIL=support@advision.com
