# Smile installer — set one when hosting is ready.
#
# Option A (recommended): stable "latest" redirect on your CDN
# SMILE_DOWNLOAD_URL=https://downloads.example.com/smile/latest
#
# Option B: versioned files on a CDN bucket root
# SMILE_DOWNLOAD_BASE_URL=https://downloads.example.com/smile

# Support email shown on /smile/support and legal pages
# SMILE_SUPPORT_EMAIL=support@yourdomain.com
