# Copy to Netlify: Site settings → Environment variables → Production
# (Vercel env vars do not migrate automatically.)
#
# Download URL is optional when the .dmg lives in public/ (e.g. public/Smile-0.25.1.dmg).
# The site auto-serves /Smile-{version}.dmg from lib/releases/smile.ts — do NOT set
# SMILE_DOWNLOAD_URL on Netlify unless you host the installer elsewhere (it overrides the version).
#
# SMILE_DOWNLOAD_URL=https://avison-soft.com/Smile-0.25.1.dmg
# SMILE_DOWNLOAD_BASE_URL=https://downloads.example.com/smile

# Support email shown on /smile/support and legal pages
# SMILE_SUPPORT_EMAIL=support@avison-soft.com
